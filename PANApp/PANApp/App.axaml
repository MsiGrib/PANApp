<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PANApp.App"
             xmlns:local="using:PANApp"
             xmlns:converters="using:PANApp.Converters"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <converters:NotEmptyConverter x:Key="NotEmptyConverter"/>
        <converters:StringEqualsConverter x:Key="StringEqualsConverter"/>
        <converters:SimpleBoolConverter x:Key="SimpleBoolConverter"/>
        <converters:BoolToTextConverter x:Key="BoolToTextConverter"/>
    </Application.Resources>

</Application>